<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050403"
    android:keepScreenOn="true">

    <SurfaceView
        android:id="@+id/scene_surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/app_name" />

    <ScrollView
        android:id="@+id/diagnostics_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F20A0908"
        android:fillViewport="true"
        android:padding="24dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/diagnostics_back"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/back" />

            <TextView
                android:id="@+id/report_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:paddingTop="16dp"
                android:textColor="#D8F0D0"
                android:textIsSelectable="true"
                android:textSize="12sp" />
        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/rt_status"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="16dp"
        android:background="#B30D0B09"
        android:gravity="center"
        android:ellipsize="end"
        android:maxWidth="360dp"
        android:maxLines="1"
        android:minWidth="260dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="@string/rt_starting"
        android:textColor="#FFD07A"
        android:textSize="9sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/developer_overlay"
        android:layout_width="360dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="16dp"
        android:layout_marginTop="64dp"
        android:background="#D90D0B09"
        android:clickable="false"
        android:enabled="false"
        android:focusable="false"
        android:fontFamily="monospace"
        android:importantForAccessibility="no"
        android:maxLines="7"
        android:padding="8dp"
        android:textColor="#D8F0D0"
        android:textSize="8sp"
        android:visibility="gone" />

    <Button
        android:id="@+id/menu_button"
        android:layout_width="72dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:text="@string/menu"
        android:textSize="12sp" />

    <Button
        android:id="@+id/attack_button"
        android:layout_width="104dp"
        android:layout_height="72dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        android:text="@string/swing"
        android:textSize="17sp"
        android:textStyle="bold" />

    <FrameLayout
        android:id="@+id/menu_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#C7080706" />

</FrameLayout>
